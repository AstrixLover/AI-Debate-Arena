run = "python -m streamlit run main.py --server.port 8080 --server.address 0.0.0.0"
modules = ["python-3.11"]

[[ports]]
localPort = 8080
externalPort = 80

[nix]
packages = ["psmisc", "streamlit"]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash /home/runner/workspace/start.sh"
waitForPort = 8080

[agent]
expertMode = true
